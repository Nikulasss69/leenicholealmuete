    }

    li {
        margin: 6px 0;
        transition: color 0.3s ease;
    }

    li:hover {
        color: #6c63ff;
        cursor: pointer;
    }

    footer {
        text-align: center;
        background: #1f1c2c;
        color: white;
        padding: 15px;
        margin-top: 30px;
    }

    a {
        color: #6c63ff;
        text-decoration: none;
    }

    a:hover {
